<?xml version="1.0" encoding="utf-8"?>
<!--
  item_chat_suggestion.xml — the "Suggested Activity" card (WinWell's signature feature).
  Shows a wellness activity loaded from Firestore, with Accept / Decline buttons.
  In Auto-pilot mode the buttons are hidden and a status line is shown instead.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/chat_suggestion_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <androidx.cardview.widget.CardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="32dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@android:color/transparent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_suggestion"
            android:padding="14dp"
            android:maxWidth="280dp">

            <!-- Card label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/suggested_activity"
                android:textColor="@color/navy_blue"
                android:textStyle="bold"
                android:textSize="12sp"
                android:letterSpacing="0.05"/>

            <!-- Activity title -->
            <TextView
                android:id="@+id/text_activity_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/navy_blue"
                android:textStyle="bold"
                android:textSize="16sp"/>

            <!-- Activity description -->
            <TextView
                android:id="@+id/text_activity_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"/>

            <!-- Accept / Decline buttons (shown in Co-pilot mode) -->
            <LinearLayout
                android:id="@+id/buttons_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="end">

                <Button
                    android:id="@+id/btn_decline"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="@string/decline"
                    android:textAllCaps="false"
                    android:textColor="@color/navy_blue"
                    android:textSize="13sp"
                    android:background="@drawable/bg_button_outline"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:backgroundTint="@null"/>

                <Button
                    android:id="@+id/btn_accept"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:text="@string/accept"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:background="@drawable/bg_button"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    app:backgroundTint="@null"/>

            </LinearLayout>

            <!-- Status line (shown after Accept/Decline, or in Auto-pilot mode) -->
            <TextView
                android:id="@+id/text_suggestion_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textColor="@color/navy_blue"
                android:textStyle="bold"
                android:textSize="13sp"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
